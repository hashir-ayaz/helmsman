{
    "swagger": "2.0",
    "info": {
        "description": "Local Kubernetes cluster management API. Connects to whichever cluster your kubeconfig points at.",
        "title": "Helmsman API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/api/v1/contexts": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "contexts"
                ],
                "summary": "List kubeconfig contexts",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/handler.APIResponse"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/definitions/cluster.ContextInfo"
                                            }
                                        }
                                    }
                                }
                            ]
                        }
                    }
                }
            }
        },
        "/api/v1/contexts/{ctx}/namespaces/{ns}/deployments/{name}/scale": {
            "post": {
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "actions"
                ],
                "summary": "Scale a workload",
                "responses": {}
            }
        },
        "/api/v1/contexts/{ctx}/namespaces/{ns}/pods/{name}/log": {
            "get": {
                "produces": [
                    "text/event-stream"
                ],
                "tags": [
                    "logs"
                ],
                "summary": "Stream pod logs (SSE)",
                "responses": {}
            }
        },
        "/api/v1/contexts/{ctx}/namespaces/{ns}/resources/{resource}/{name}": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "resources"
                ],
                "summary": "Get one resource",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/handler.APIResponse"
                        }
                    }
                }
            },
            "delete": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "resources"
                ],
                "summary": "Delete one resource",
                "responses": {}
            },
            "patch": {
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "resources"
                ],
                "summary": "Patch one resource (merge patch)",
                "responses": {}
            }
        },
        "/api/v1/contexts/{ctx}/namespaces/{ns}/resources/{resource}/{name}/yaml": {
            "get": {
                "produces": [
                    "text/plain"
                ],
                "tags": [
                    "resources"
                ],
                "summary": "Get one resource as YAML",
                "responses": {}
            }
        },
        "/api/v1/contexts/{ctx}/namespaces/{ns}/{workload}/{name}/restart": {
            "post": {
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "actions"
                ],
                "summary": "Rollout restart a workload",
                "responses": {}
            }
        },
        "/api/v1/contexts/{ctx}/resources": {
            "post": {
                "consumes": [
                    "text/plain"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "resources"
                ],
                "summary": "Apply a YAML manifest (server-side apply)",
                "responses": {}
            }
        },
        "/api/v1/contexts/{ctx}/resources/{resource}": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "resources"
                ],
                "summary": "List resources (server-side table)",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Context name or _current",
                        "name": "ctx",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Resource (e.g. pods, deployments.apps)",
                        "name": "resource",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/handler.APIResponse"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/definitions/handler.TablePayload"
                                        }
                                    }
                                }
                            ]
                        }
                    }
                }
            }
        },
        "/api/v1/contexts/{ctx}/resources/{resource}/{name}": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "resources"
                ],
                "summary": "Get one resource",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/handler.APIResponse"
                        }
                    }
                }
            },
            "delete": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "resources"
                ],
                "summary": "Delete one resource",
                "responses": {}
            },
            "patch": {
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "resources"
                ],
                "summary": "Patch one resource (merge patch)",
                "responses": {}
            }
        },
        "/api/v1/contexts/{ctx}/resources/{resource}/{name}/yaml": {
            "get": {
                "produces": [
                    "text/plain"
                ],
                "tags": [
                    "resources"
                ],
                "summary": "Get one resource as YAML",
                "responses": {}
            }
        }
    },
    "definitions": {
        "cluster.ContextInfo": {
            "type": "object",
            "properties": {
                "cluster": {
                    "type": "string"
                },
                "isCurrent": {
                    "type": "boolean"
                },
                "name": {
                    "type": "string"
                },
                "namespace": {
                    "type": "string"
                }
            }
        },
        "handler.APIResponse": {
            "type": "object",
            "properties": {
                "data": {},
                "error": {
                    "type": "string"
                }
            }
        },
        "handler.RowObject": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string"
                },
                "namespace": {
                    "type": "string"
                },
                "uid": {
                    "type": "string"
                }
            }
        },
        "handler.TableColumn": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string"
                },
                "priority": {
                    "type": "integer"
                },
                "type": {
                    "type": "string"
                }
            }
        },
        "handler.TablePayload": {
            "type": "object",
            "properties": {
                "columns": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/handler.TableColumn"
                    }
                },
                "rows": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/handler.TableRow"
                    }
                }
            }
        },
        "handler.TableRow": {
            "type": "object",
            "properties": {
